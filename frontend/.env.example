# ============================================================
#  frontend/.env  —  App Vue 3 (PWA)
#  Copia este archivo como ".env" y rellena tus valores.
# ============================================================

# Nombre del taller que se muestra en la interfaz
VITE_NOMBRE_TALLER="Mi Taller"

# URL base de la API de Django (sin barra final)
# En desarrollo con túnel: https://xxxxx-8000.devtunnels.ms/api
# En local directo:        http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api
