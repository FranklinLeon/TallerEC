# ============================================================
#  core/.env  —  Backend Django
#  Copia este archivo como ".env" y rellena tus valores.
# ============================================================

# Clave secreta de Django. Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-unica

# --- WhatsApp Cloud API (Meta) ---
# Se obtienen en https://developers.facebook.com/ > tu app > WhatsApp
WHATSAPP_TOKEN=TU_TOKEN_DE_WHATSAPP
WHATSAPP_PHONE_ID=000000000000000
WHATSAPP_BUSINESS_ID=000000000000000
WHATSAPP_VERIFY_TOKEN=un-token-de-verificacion-a-tu-eleccion

# --- URL pública del frontend (para los links de seguimiento) ---
# En desarrollo suele ser un túnel (ngrok / VS Code dev tunnel) o http://localhost:5173
VITE_URL_FRONTEND=http://localhost:5173
