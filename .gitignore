# ============================================================
#  TallerEC — .gitignore
# ============================================================

# ---- Secretos y credenciales (NUNCA subir) ----
**/.env
**/.env.*
!**/.env.example
ai_service/google_key.json
*.pem
*.key

# ---- Datos reales de clientes (privacidad) ----
core/db.sqlite3
*.sqlite3
core/media/
ai_service/temp_*
ai_service/*.jpg
ai_service/*.jpeg
ai_service/*.png
ai_service/*.mp3
ai_service/*.wav
ai_service/*.m4a

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/

# ---- Node / Frontend ----
node_modules/
dist/
dev-dist/
.vite/
*.local

# ---- PWA build artifacts ----
frontend/dist/
frontend/dev-dist/

# ---- Editores / SO ----
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ---- Herramientas locales de IA ----
.claude/settings.local.json

# ---- Logs ----
*.log
npm-debug.log*

# Documentos de estrategia/roadmap (privados, solo local)
roadmap.txt
Documentacion/

# Instrucciones locales para IA (privado)
CLAUDE.md
